# ============================================================
# VagaCerta — Environment Variables
# Copie para .env.local (dev) ou configure na Vercel (prod)
# ============================================================

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----- Supabase -----
# Pegar em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # CUIDADO: server-only, nunca expor

# ----- Anthropic -----
# Pegar em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ----- Mercado Pago -----
# Pegar em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...        # produção
MERCADOPAGO_PUBLIC_KEY=APP_USR-...           # frontend (opcional no Checkout Pro)
MERCADOPAGO_WEBHOOK_SECRET=...               # para validar assinatura do webhook

# ----- Resend (email transacional) -----
# Pegar em: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ola@seudominio.com.br

# ----- Analytics (opcional) -----
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=seudominio.com.br
# OU
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
